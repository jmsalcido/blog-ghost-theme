<a href="{{url}}" class="post-list-item">

  <div class="post-list-content">
    {{#primary_tag}}
      <span class="post-tag">{{name}}</span>
    {{/primary_tag}}
    <h3 class="post-list-title">{{title}}</h3>
    <p class="post-list-excerpt">{{excerpt words="25"}}</p>
    <div class="post-meta">
      <span>{{date published_at format="MMM D, YYYY"}}</span>
      <span aria-hidden="true">·</span>
      <span>{{reading_time}}</span>
    </div>
  </div>

  {{#if feature_image}}
  <div class="post-list-thumbnail">
    <img
      src="{{img_url feature_image size="s"}}"
      alt="{{title}}"
      loading="lazy">
  </div>
  {{/if}}

</a>
