    <a href="{{@site.url}}" class="gh-foot-brand">
      <span class="gh-foot-brand-dot" aria-hidden="true"></span>
      {{@site.title}}
    </a>

    <nav class="gh-foot-nav" aria-label="Footer navigation">
      <ul role="list">
        {{navigation type="secondary"}}
      </ul>
    </nav>

    <p class="gh-foot-copy">© {{date format="YYYY"}} · Built on Ghost</p>

  </div>
</footer>
