{{!< default}}

<div class="gh-main-wrap">
  <div class="gh-container">

    <header class="gh-section-header">
      <span class="gh-section-eyebrow">Field notes</span>
      <span class="rule-accent"></span>
      <h1 class="gh-section-title">Building real systems: software, SaaS, coffee, and operations from Mexico.</h1>
      <p class="gh-section-subtitle">Personal notes from Jose Salcido on turning ideas into working products, running small businesses, learning through coffee, and staying honest about the process.</p>
    </header>

    {{#get "posts" filter="featured:true" limit="3"}}
      {{#if posts}}
      <section class="gh-discovery-section" aria-labelledby="featured-posts">
        <div class="gh-discovery-header">
          <span class="rule-accent"></span>
          <h2 id="featured-posts" class="gh-discovery-title">Featured posts</h2>
        </div>
        <div class="gh-post-grid">
          {{#foreach posts}}
            {{> post-card}}
          {{/foreach}}
        </div>
      </section>
      {{/if}}
    {{/get}}

    {{#get "tags" limit="8" order="count.posts desc"}}
      {{#if tags}}
      <section class="gh-topic-strip" aria-labelledby="topics">
        <div>
          <span class="gh-section-eyebrow">Topics</span>
          <h2 id="topics" class="gh-topic-title">Software, business, coffee, and personal operating notes.</h2>
        </div>
        <div class="gh-topic-list">
          {{#foreach tags}}
            <a href="{{url}}" class="gh-tag-pill">{{name}}</a>
          {{/foreach}}
        </div>
      </section>
      {{/if}}
    {{/get}}

    <section class="gh-discovery-section" aria-labelledby="recent-posts">
      <div class="gh-discovery-header">
        <span class="rule-accent"></span>
        <h2 id="recent-posts" class="gh-discovery-title">Recent posts</h2>
      </div>

      <div class="gh-post-grid">
        {{#foreach posts}}
          {{> post-card}}
        {{/foreach}}
      </div>

      {{pagination}}
    </section>

    {{#get "posts" include="tags" limit="6" filter="tag:[cafe,personal]"}}
      {{#if posts}}
      <section class="gh-discovery-section" aria-labelledby="explore-more">
        <div class="gh-discovery-header">
          <span class="rule-accent"></span>
          <h2 id="explore-more" class="gh-discovery-title">Explore more</h2>
        </div>
        <div class="gh-post-grid gh-post-grid--compact">
          {{#foreach posts}}
            {{> post-card}}
          {{/foreach}}
        </div>
      </section>
      {{/if}}
    {{/get}}

    {{> newsletter}}

  </div>
</div>
