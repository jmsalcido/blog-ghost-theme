<!DOCTYPE html>
<html lang="{{@site.locale}}" class="has-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{#is "home"}}{{@site.title}} | Software, SaaS, Coffee, and Operations from Mexico{{else}}{{meta_title}}{{#is "post, page, tag, author"}} | {{@site.title}}{{/is}}{{/is}}</title>
  {{ghost_head}}
  {{#is "paged"}}
    <meta name="robots" content="noindex,follow">
  {{/is}}
  {{> seo-structured-data}}
  <link rel="stylesheet" type="text/css" href="{{asset "css/main.css"}}">
</head>
<body class="{{body_class}}">

{{> header}}

<main id="main">
  {{{body}}}
</main>

{{> footer}}

<script src="{{asset "js/theme.js"}}"></script>
{{ghost_foot}}
</body>
</html>
